{
  "buildCommand": "cd frontend && npm run build",
  "installCommand": "cd backend && npm install && cd ../frontend && npm install",
  "outputDirectory": "frontend/build",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "create-react-app"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  }
}
